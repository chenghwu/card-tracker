# Django Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Leave DB_NAME empty for SQLite in development)
# For PostgreSQL/Supabase, set all DB_* variables
DB_NAME=
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=your-project.supabase.co
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Social Authentication - Google OAuth
# Get credentials from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Social Authentication - Apple OAuth
# Get credentials from: https://developer.apple.com/
# Follow Apple's "Sign in with Apple" setup guide
# Service ID should be a reverse domain (e.g., com.yourapp.cardtracker)
# You'll need to create a Service ID, Key, and configure the domain/redirect URLs
APPLE_CLIENT_ID=com.yourapp.cardtracker
APPLE_CLIENT_SECRET=your-apple-client-secret-or-key-id

# Email Configuration (for sending reminder emails)
DEFAULT_FROM_EMAIL=noreply@cardtracker.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password

# Gemini AI (Optional - for card lookup feature)
# Get API key from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key

# Frontend URL — used for OAuth redirects after social login.
# In production set this to your Vercel deployment URL (no trailing slash).
FRONTEND_URL=http://localhost:3000

# CORS allowed origins — comma-separated list of origins allowed to make
# cross-origin requests to the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Production Security Settings (set these in production)
SECURE_SSL_REDIRECT=True
DJANGO_LOG_LEVEL=INFO
